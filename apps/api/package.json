{
  "name": "@taxora/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:apply-invariants": "psql \"$DATABASE_URL\" -f prisma/sql/01_invariants.sql && psql \"$DATABASE_URL\" -f prisma/sql/02_ai_vector.sql",
    "db:proof": "tsx scripts/proof.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/helmet": "11.1.1",
    "@nestjs/common": "^10.4.7",
    "@nestjs/core": "^10.4.7",
    "@nestjs/platform-fastify": "^10.4.7",
    "@prisma/client": "^5.22.0",
    "@taxora/accounting": "workspace:*",
    "@taxora/rule-engine": "workspace:*",
    "@taxora/tax-rules": "workspace:*",
    "fastify": "4.28.1",
    "jose": "^5.9.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.0"
  }
}
