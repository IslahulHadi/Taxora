NODE_ENV=development

# ─── API server ──────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
CORS_ALLOW_ORIGIN=http://localhost:3000

# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://taxora:taxora@localhost:5432/taxora?schema=public

# ─── Cache / queue ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ───────────────────────────────────────────────
# Must be >=16 chars. Generate with: openssl rand -base64 32
JWT_SECRET=dev-only-change-me-please-32chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# Set to 'true' to enable the dev-login endpoint. NEVER true in prod.
ENABLE_DEV_LOGIN=true

# ─── AI providers (set only what you use) ───────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_PROVIDER=openai

# ─── OCR ────────────────────────────────────────────────
OCR_PROVIDER=tesseract

# ─── Mail ───────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025

# ─── Object storage (faktur PDF, OCR uploads) ───────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=taxora-dev
